{
  "name": "eswat42",
  "version": "2.1.110",
  "description": "A personal card for Richard Hess (@eswat42)",
  "main": "/bin/card.js",
  "bin": {
    "eswat2": "./bin/card.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/eswat2/eswat42.git"
  },
  "scripts": {
    "bump": "bumpp patch --commit --tag --push --yes",
    "card": "node ./bin/card.js",
    "release": "pnpm bump && pnpm build && pnpm card && pnpm publish",
    "preinstall": "npx only-allow pnpm",
    "build": "node build.mjs",
    "dev": "pnpm build && pnpm card",
    "lint": "standard",
    "test": "echo skipping tests...",
    "open": "npx eswat42@latest"
  },
  "keywords": [
    "card",
    "npm",
    "npm card",
    "npx",
    "npx card",
    "business card"
  ],
  "author": "Tierney Cyren <hello@bnb.im> (http://bnb.im)",
  "license": "MIT",
  "files": [
    "bin/card.js",
    "bin/output"
  ],
  "devDependencies": {
    "boxen": "8.0.1",
    "bumpp": "11.1.0",
    "only-allow": "1.2.2",
    "picocolors": "1.1.1",
    "standard": "17.1.2",
    "yoctocolors": "2.1.2"
  },
  "packageManager": "pnpm@11.0.9+sha512.34ce82e6780233cf9cad8685029a8f81d2e06196c5a9bad98879f7424940c6817c4e4524fb7d38b8553ceed48b9758b8ebaf1abd3600c232c4c8cf7366086f38"
}
